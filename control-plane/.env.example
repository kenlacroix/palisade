# Copy to .env. These are the ONLY things that change between laptop, Proxmox,
# and the VPS — code carries no host-specific values.

# --- startup security gate ---
# On a Postgres deployment the control plane REFUSES TO BOOT while any public
# default secret is still in place (DB password 'palisade:palisade', the public
# catalog-signing seed, the demo login password, or a missing evidence KEK).
# This flag downgrades that hard failure to logged warnings. It is set to 1 here
# so the one-command local Docker stack (`make up`) works out of the box.
# BEFORE EXPOSING THIS INSTANCE: set this to 0 (or remove it) and replace every
# default below with a real secret. Generate fresh secrets:
#   DB password:   openssl rand -hex 24
#   signing seed:  python -c "import os,base64;print(base64.b64encode(os.urandom(32)).decode())"
#   evidence KEK:  python -c "import os,base64;print(base64.b64encode(os.urandom(32)).decode())"
PALISADE_ALLOW_INSECURE_DEFAULTS=1

# Database. Compose default points at the bundled Postgres service.
# Local-without-Docker quick run: leave unset to use sqlite:///./palisade.db
# PRODUCTION: change the password (both here and POSTGRES_PASSWORD).
DATABASE_URL=postgresql+psycopg://palisade:palisade@postgres:5432/palisade
POSTGRES_USER=palisade
POSTGRES_PASSWORD=palisade
POSTGRES_DB=palisade

# Master key-encryption key (base64, 32 bytes) for data-at-rest: wraps each
# org's evidence data key AND seals the internal mTLS CA private key. Unset =>
# both are stored as plaintext (dev only). PRODUCTION: set a real KEK.
# PALISADE_EVIDENCE_KEK=

# Durable job queue. Compose default points at the bundled Redis service and
# runs the `worker` container. Local-without-Docker: leave unset and triage +
# alert delivery fall back to in-process background tasks (no Redis needed).
REDIS_URL=redis://redis:6379

# Deployment environment. Set to "production" on the VPS to enable hardening
# guards — notably, the app refuses to boot if it would seed the well-known
# demo enroll token. Default "dev" keeps local/demo one-click.
# PALISADE_ENV=production

# Comma-separated, single-use enrollment tokens accepted by POST /v1/agents/enroll.
# Each token mints exactly one agent and binds it to the token's org, then is
# marked used. Seeded into the demo org at bootstrap with a TTL (below) and
# re-armed on each boot. VPS: replace with strong, rotated secrets — the default
# PLS-DEMO is rejected when PALISADE_ENV=production.
PALISADE_ENROLL_TOKENS=PLS-DEMO
# Lifetime of an env-seeded bootstrap enroll token, in seconds. Default 24h.
PALISADE_BOOTSTRAP_TOKEN_TTL_S=86400

# --- multi-tenancy (M1) ---
# Demo user seeded into the demo org (owner) so the web UI logs in with one click.
# VPS: change these or remove the demo user before exposing the instance — the
# default password is rejected at boot when PALISADE_ENV=production.
PALISADE_DEMO_USER_EMAIL=demo@palisade.local
PALISADE_DEMO_USER_PASSWORD=palisade
# Web UI session (bearer token) lifetime in seconds. Default 7 days.
PALISADE_SESSION_TTL_S=604800

# Comma-separated CORS origins (where the web/ UI is served from).
# VPS: set to https://palisade.sh (or your domain).
PALISADE_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# --- agent mTLS (production hardening) ---
# Agents enroll over plaintext http with a bearer agent_secret (the demo path).
# In production, terminate TLS at a reverse proxy that verifies the client cert
# against the control plane's CA and forwards the PEM in PALISADE_MTLS_HEADER.
# When PALISADE_REQUIRE_MTLS is on, the bearer fallback is rejected and a valid
# client cert is required on every agent call. DEFAULT: on in production (a
# Postgres deploy without PALISADE_ALLOW_INSECURE_DEFAULTS), off for dev/demo.
# Set explicitly to override either way.
# PALISADE_REQUIRE_MTLS=1
# Header the proxy uses to forward the (URL-escaped) PEM client cert.
# nginx: proxy_set_header X-Client-Cert $ssl_client_escaped_cert;
PALISADE_MTLS_HEADER=x-client-cert
# Validity window (days) for client certs issued at enroll. Default 397.
PALISADE_MTLS_CERT_DAYS=397

# Host port the API binds to.
API_PORT=8000

# AI drafting for "New from CVE URL" (POST /v1/detections/draft). Unset -> 503.
# ANTHROPIC_API_KEY=
# PALISADE_DRAFT_MODEL=claude-opus-4-8
# AI triage of new findings (best-effort, inline). Uses ANTHROPIC_API_KEY above.
# PALISADE_TRIAGE_MODEL=claude-haiku-4-5-20251001

# --- Catalog bundle signing (SPEC 5.4) ---
# Ed25519 secret seed (base64) used to sign the catalog bundle. Unset OR set to
# the demo seed below means agents will accept bundles signed by the PUBLIC demo
# key — i.e. anyone can forge a catalog. PRODUCTION: generate a fresh seed (see
# the top of this file), set it here, and pin its public key on agents via
# PALISADE_CATALOG_PUBKEY. The startup gate rejects the demo/unset seed in prod.
# Demo keypair (matches the agent's pinned public key — DEMO ONLY):
# PALISADE_SIGNING_KEY=70kJtI1NajTd1yQXFHVRuBVQfc6P2CAtRroaLCmYYbY=
