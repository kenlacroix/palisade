# Copy to .env. These are the ONLY things that change between laptop, Proxmox,
# and the VPS — code carries no host-specific values.

# Database. Compose default points at the bundled Postgres service.
# Local-without-Docker quick run: leave unset to use sqlite:///./palisade.db
DATABASE_URL=postgresql+psycopg://palisade:palisade@postgres:5432/palisade
POSTGRES_USER=palisade
POSTGRES_PASSWORD=palisade
POSTGRES_DB=palisade

# Comma-separated, single-use enrollment tokens accepted by POST /v1/agents/enroll.
# Each token mints exactly one agent and binds it to the token's org, then is
# marked used. Seeded into the demo org at bootstrap.
# VPS: replace with strong, rotated secrets.
PALISADE_ENROLL_TOKENS=PLS-DEMO

# --- multi-tenancy (M1) ---
# Demo user seeded into the demo org (owner) so the web UI logs in with one click.
# VPS: change these or remove the demo user before exposing the instance.
PALISADE_DEMO_USER_EMAIL=demo@palisade.local
PALISADE_DEMO_USER_PASSWORD=palisade
# Web UI session (bearer token) lifetime in seconds. Default 7 days.
PALISADE_SESSION_TTL_S=604800

# Comma-separated CORS origins (where the web/ UI is served from).
# VPS: set to https://palisade.sh (or your domain).
PALISADE_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# --- agent mTLS (production hardening) ---
# Agents enroll over plaintext http with a bearer agent_secret (the demo path).
# In production, terminate TLS at a reverse proxy that verifies the client cert
# against the control plane's CA and forwards the PEM in PALISADE_MTLS_HEADER.
# When PALISADE_REQUIRE_MTLS is on, the bearer fallback is rejected and a valid
# client cert is required on every agent call.
# PALISADE_REQUIRE_MTLS=1
# Header the proxy uses to forward the (URL-escaped) PEM client cert.
# nginx: proxy_set_header X-Client-Cert $ssl_client_escaped_cert;
PALISADE_MTLS_HEADER=x-client-cert
# Validity window (days) for client certs issued at enroll. Default 397.
PALISADE_MTLS_CERT_DAYS=397

# Host port the API binds to.
API_PORT=8000

# AI drafting for "New from CVE URL" (POST /v1/detections/draft). Unset -> 503.
# ANTHROPIC_API_KEY=
# PALISADE_DRAFT_MODEL=claude-opus-4-8
# AI triage of new findings (best-effort, inline). Uses ANTHROPIC_API_KEY above.
# PALISADE_TRIAGE_MODEL=claude-haiku-4-5-20251001

# --- Catalog bundle signing (SPEC 5.4) ---
# Ed25519 secret seed (base64) used to sign the catalog bundle. Unset -> bundle ships unsigned ("stub").
# Demo keypair (matches the agent's pinned public key):
# PALISADE_SIGNING_KEY=70kJtI1NajTd1yQXFHVRuBVQfc6P2CAtRroaLCmYYbY=
