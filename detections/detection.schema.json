{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://palisade.dev/schemas/detection.schema.json",
  "title": "Palisade Detection",
  "description": "Schema for a single Palisade detection (YAML/JSON). Matches the wire Detection shape served by GET /v1/catalog/bundle.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "title",
    "cve",
    "severity",
    "category",
    "engine",
    "match",
    "remediation",
    "references",
    "signature"
  ],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "cve": {
      "type": "string",
      "pattern": "^CVE-[0-9]{4}-[0-9]{4,}$"
    },
    "severity": {
      "type": "string",
      "enum": ["critical", "high", "medium", "low", "info"]
    },
    "category": {
      "type": "string",
      "enum": ["ai-infra", "self-hosted", "web", "backup", "observability"]
    },
    "engine": {
      "type": "string",
      "enum": ["nuclei", "module"]
    },
    "match": {
      "type": "object",
      "additionalProperties": false,
      "required": ["service", "versions"],
      "properties": {
        "service": { "type": "string", "minLength": 1 },
        "versions": { "type": "string", "minLength": 1 }
      }
    },
    "http": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["method", "path", "matchers"],
        "properties": {
          "method": {
            "type": "string",
            "enum": ["GET", "POST", "PUT", "PATCH", "DELETE", "HEAD", "OPTIONS"]
          },
          "path": { "type": "string", "minLength": 1 },
          "body": { "type": "string" },
          "matchers-condition": {
            "type": "string",
            "enum": ["and", "or"]
          },
          "matchers": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["type"],
              "properties": {
                "type": {
                  "type": "string",
                  "enum": ["dsl", "word", "status", "regex", "binary"]
                },
                "dsl": {
                  "type": "array",
                  "items": { "type": "string" }
                },
                "words": {
                  "type": "array",
                  "items": { "type": "string" }
                },
                "status": {
                  "type": "array",
                  "items": { "type": "integer" }
                },
                "regex": {
                  "type": "array",
                  "items": { "type": "string" }
                },
                "binary": {
                  "type": "array",
                  "items": { "type": "string", "pattern": "^(0x)?[0-9a-fA-F]+$" }
                },
                "part": {
                  "type": "string",
                  "enum": ["body", "header"]
                },
                "negative": { "type": "boolean" }
              },
              "allOf": [
                {
                  "if": { "properties": { "type": { "const": "dsl" } } },
                  "then": { "required": ["dsl"] }
                },
                {
                  "if": { "properties": { "type": { "const": "word" } } },
                  "then": { "required": ["words"] }
                },
                {
                  "if": { "properties": { "type": { "const": "status" } } },
                  "then": { "required": ["status"] }
                },
                {
                  "if": { "properties": { "type": { "const": "regex" } } },
                  "then": { "required": ["regex"] }
                },
                {
                  "if": { "properties": { "type": { "const": "binary" } } },
                  "then": { "required": ["binary"] }
                }
              ]
            }
          }
        }
      }
    },
    "spec_ref": {
      "type": "string",
      "minLength": 1
    },
    "flow": {
      "type": "object",
      "additionalProperties": false,
      "required": ["requests", "confirm"],
      "properties": {
        "requests": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["id", "method", "path"],
            "properties": {
              "id": { "type": "string", "minLength": 1 },
              "method": {
                "type": "string",
                "enum": ["GET", "POST", "PUT", "PATCH", "DELETE", "HEAD", "OPTIONS"]
              },
              "path": { "type": "string", "minLength": 1 },
              "body": { "type": "string" },
              "headers": {
                "type": "object",
                "additionalProperties": { "type": "string" }
              }
            }
          }
        },
        "confirm": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "cvss": {
      "type": "number",
      "minimum": 0,
      "maximum": 10
    },
    "remediation": {
      "type": "string",
      "minLength": 1
    },
    "references": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "format": "uri" }
    },
    "signature": {
      "type": "string",
      "minLength": 1
    }
  },
  "allOf": [
    {
      "if": { "properties": { "engine": { "const": "nuclei" } } },
      "then": {
        "required": ["http"],
        "not": { "required": ["spec_ref"] }
      }
    },
    {
      "if": { "properties": { "engine": { "const": "module" } } },
      "then": {
        "anyOf": [{ "required": ["spec_ref"] }, { "required": ["flow"] }],
        "not": { "required": ["http"] }
      }
    }
  ]
}
