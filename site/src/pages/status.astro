---
import Layout from "../layouts/Layout.astro";
import { SITE } from "../config";

const services = [
  {
    id: "site",
    name: "Marketing site",
    detail: "trypalisade.dev",
    url: "/",
    mode: "cors",
  },
  {
    id: "app",
    name: "Dashboard app",
    detail: "app.trypalisade.dev",
    url: `${SITE.appUrl}/`,
    mode: "no-cors",
  },
  {
    id: "api",
    name: "Control plane API",
    detail: "api.trypalisade.dev",
    url: "https://api.trypalisade.dev/healthz",
    mode: "cors",
  },
];
---

<Layout
  title="Status"
  description="Live status of the Palisade marketing site, dashboard app, and control-plane API."
>
  <section class="py-20">
    <div class="container-x">
      <p class="eyebrow">System status</p>
      <h1 class="mt-4 text-3xl font-bold tracking-tight text-white sm:text-4xl">Service status</h1>

      <div id="overall" class="card mt-8 flex items-center gap-3">
        <span id="overall-dot" class="h-3 w-3 shrink-0 animate-pulse rounded-full bg-slate-500"></span>
        <div>
          <div id="overall-label" class="font-semibold text-white">Checking services…</div>
          <div class="text-sm text-slate-500">
            Last checked <span id="checked-at">—</span>
          </div>
        </div>
      </div>

      <div class="mt-6 divide-y divide-ink-700 overflow-hidden rounded-xl border border-ink-700 bg-ink-800/60">
        {
          services.map((s) => (
            <div class="flex items-center justify-between gap-4 p-5" data-row={s.id}>
              <div>
                <div class="font-medium text-white">{s.name}</div>
                <div class="font-mono text-xs text-slate-500">{s.detail}</div>
              </div>
              <div class="flex items-center gap-3">
                <span class="text-xs text-slate-500" data-latency={s.id} />
                <span
                  class="inline-flex items-center gap-2 rounded-full border border-ink-600 px-3 py-1 text-xs font-medium text-slate-400"
                  data-badge={s.id}
                >
                  <span class="h-2 w-2 animate-pulse rounded-full bg-slate-500" data-dot={s.id} />
                  Checking…
                </span>
              </div>
            </div>
          ))
        }
      </div>

      <p class="prose-muted mt-6 max-w-2xl text-sm">
        Checks run live from your browser and re-run every 30 seconds — there is no
        historical uptime store (this is a proof of concept). The control plane is
        self-hosted behind a Cloudflare Tunnel; the site and app are on Cloudflare
        Pages. Source on <a href={SITE.repoUrl} target="_blank" rel="noopener" class="text-accent-fg hover:text-white">GitHub</a>.
      </p>
    </div>
  </section>

  <script define:vars={{ services }}>
    const TIMEOUT = 8000;
    const checkedAt = document.getElementById("checked-at");
    const overallDot = document.getElementById("overall-dot");
    const overallLabel = document.getElementById("overall-label");

    function set(el, cls) { el.className = cls; }

    async function ping(svc) {
      const ctrl = new AbortController();
      const timer = setTimeout(() => ctrl.abort(), TIMEOUT);
      const started = performance.now();
      try {
        const res = await fetch(svc.url, { mode: svc.mode, cache: "no-store", signal: ctrl.signal });
        clearTimeout(timer);
        // no-cors yields an opaque response (type "opaque"); reaching here means it responded.
        const ok = svc.mode === "no-cors" ? true : res.ok;
        return { up: ok, ms: Math.round(performance.now() - started) };
      } catch (e) {
        clearTimeout(timer);
        return { up: false, ms: null };
      }
    }

    function render(id, r) {
      const badge = document.querySelector('[data-badge="' + id + '"]');
      const dot = document.querySelector('[data-dot="' + id + '"]');
      const lat = document.querySelector('[data-latency="' + id + '"]');
      if (r.up) {
        badge.className = "inline-flex items-center gap-2 rounded-full border border-emerald-500/30 bg-emerald-500/10 px-3 py-1 text-xs font-medium text-emerald-400";
        badge.lastChild.textContent = " Operational";
        set(dot, "h-2 w-2 rounded-full bg-emerald-400");
        lat.textContent = r.ms != null ? r.ms + " ms" : "";
      } else {
        badge.className = "inline-flex items-center gap-2 rounded-full border border-red-500/30 bg-red-500/10 px-3 py-1 text-xs font-medium text-red-400";
        badge.lastChild.textContent = " Down";
        set(dot, "h-2 w-2 rounded-full bg-red-400");
        lat.textContent = "";
      }
    }

    async function runAll() {
      const results = await Promise.all(services.map(async (s) => [s.id, await ping(s)]));
      results.forEach(([id, r]) => render(id, r));
      const downCount = results.filter(([, r]) => !r.up).length;
      if (downCount === 0) {
        set(overallDot, "h-3 w-3 shrink-0 rounded-full bg-emerald-400");
        overallLabel.textContent = "All systems operational";
        overallLabel.className = "font-semibold text-emerald-400";
      } else if (downCount < results.length) {
        set(overallDot, "h-3 w-3 shrink-0 rounded-full bg-amber-400");
        overallLabel.textContent = "Partial outage";
        overallLabel.className = "font-semibold text-amber-400";
      } else {
        set(overallDot, "h-3 w-3 shrink-0 rounded-full bg-red-400");
        overallLabel.textContent = "Major outage";
        overallLabel.className = "font-semibold text-red-400";
      }
      checkedAt.textContent = new Date().toLocaleTimeString();
    }

    runAll();
    setInterval(runAll, 30000);
  </script>
</Layout>
