---
import Layout from "../layouts/Layout.astro";
import { SITE } from "../config";

type Feature = { title: string; body: string };

const detection: Feature[] = [
  {
    title: "Signed detection catalog",
    body: "An Ed25519 signature covers a canonical manifest. The agent rebuilds the manifest and verifies it against a pinned public key before running any detection, and fails closed on mismatch. This gives integrity over an untrusted channel.",
  },
  {
    title: "Version-aware matching",
    body: "Detections target assets by service and version range, for example <1.40.2 or >=11.1.4 <15.2.3. Unknown versions fail open so a vulnerability is never silently skipped.",
  },
  {
    title: "Pluggable detection engines",
    body: "YAML HTTP and flow detections run alongside a compiled module engine backed by a spec_ref registry in the agent. The first module covers the Next.js middleware bypass, CVE-2025-29927.",
  },
];

const trust: Feature[] = [
  {
    title: "Pull-only Go agent",
    body: "Written in Go 1.22 with the standard library only. It enrolls once, discovers listening services on-host, and runs detections locally. No inbound ports, and nothing is pushed to the host.",
  },
  {
    title: "Agent mTLS",
    body: "Enrollment issues a client certificate from an internal CA, verified at a TLS-terminating proxy. A bearer agent_secret is the plaintext-demo fallback.",
  },
  {
    title: "Encrypted evidence at rest",
    body: "Per-org AES-256-GCM under a per-org wrapped data key. Only normalized findings leave the host in the first place.",
  },
  {
    title: "Multi-tenancy + RBAC",
    body: "Users, orgs, and session auth with owner/admin/member/viewer roles, and Postgres row-level security scoped per org_id. A SECURITY DEFINER path keeps the cross-tenant catalog aggregate correct under RLS.",
  },
];

const operations: Feature[] = [
  {
    title: "Posture scoring + 30-day trends",
    body: "Posture is scored over time with real historical trends, not synthetic data.",
  },
  {
    title: "Alerting",
    body: "Channels (telegram, email, webhook) and rules combining min_severity and on_events (new or regressed) routed to a channel. Alert history is kept, channel secrets are redacted on read, and per-rule quiet hours defer delivery.",
  },
  {
    title: "AI triage + drafting",
    body: "With an ANTHROPIC_API_KEY, new findings are scored in the background off the request path with a priority, score, and rationale. New detections can be drafted from a CVE advisory URL, reviewed, and accepted, which bumps the catalog version. It no-ops without a key.",
  },
  {
    title: "Durable queue",
    body: "An Arq and Redis worker handles triage and alert delivery, with an in-process BackgroundTasks fallback when REDIS_URL is unset.",
  },
];

const stack: { component: string; path: string; tech: string }[] = [
  {
    component: "Control plane",
    path: "control-plane/",
    tech: "FastAPI + SQLAlchemy + Alembic (sqlite default, Postgres in compose)",
  },
  {
    component: "Agent",
    path: "agent/",
    tech: "Go 1.22, stdlib-only",
  },
  {
    component: "Web UI",
    path: "web/",
    tech: "React + TypeScript + Vite + Tailwind",
  },
  {
    component: "Detections",
    path: "detections/",
    tech: "YAML validated against a JSON schema",
  },
];

const groups: { heading: string; items: Feature[] }[] = [
  { heading: "Detection", items: detection },
  { heading: "Trust & isolation", items: trust },
  { heading: "Operations", items: operations },
];
---

<Layout
  title="Features"
  description="Signed detection catalog, version-aware matching, multi-tenant RBAC, agent mTLS, encrypted evidence at rest, posture trends, alerting, and AI triage."
>
  <section class="border-b border-ink-800 py-20 sm:py-28">
    <div class="container-x">
      <p class="eyebrow">Capabilities</p>
      <h1 class="mt-4 max-w-3xl text-4xl font-bold tracking-tight text-white sm:text-5xl">
        Everything Palisade does
      </h1>
      <p class="prose-muted mt-6 max-w-2xl text-lg">
        A pull-only agent, a signed and version-aware detection catalog, and a
        multi-tenant control plane that scores posture, alerts, and triages
        findings. The full capability set, grouped by what it protects.
      </p>
    </div>
  </section>

  {
    groups.map((group) => (
      <section class="border-b border-ink-800 py-20">
        <div class="container-x">
          <p class="eyebrow">{group.heading}</p>
          <div class="mt-8 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
            {group.items.map((f) => (
              <div class="card">
                <h2 class="text-lg font-semibold text-white">{f.title}</h2>
                <p class="prose-muted mt-2">{f.body}</p>
              </div>
            ))}
          </div>
        </div>
      </section>
    ))
  }

  <section class="border-b border-ink-800 py-20">
    <div class="container-x">
      <p class="eyebrow">Architecture & stack</p>
      <h2 class="mt-4 max-w-2xl text-3xl font-bold tracking-tight text-white sm:text-4xl">
        Four components, one repo
      </h2>
      <div class="mt-8 overflow-x-auto">
        <table class="w-full min-w-[640px] border-collapse text-left">
          <thead>
            <tr class="border-b border-ink-700">
              <th class="py-3 pr-6 text-xs font-medium uppercase tracking-wide text-slate-400">
                Component
              </th>
              <th class="py-3 pr-6 text-xs font-medium uppercase tracking-wide text-slate-400">
                Path
              </th>
              <th class="py-3 text-xs font-medium uppercase tracking-wide text-slate-400">
                Stack
              </th>
            </tr>
          </thead>
          <tbody>
            {
              stack.map((row) => (
                <tr class="border-b border-ink-700">
                  <td class="py-4 pr-6 font-semibold text-white">
                    {row.component}
                  </td>
                  <td class="py-4 pr-6 font-mono text-sm text-accent-fg">
                    {row.path}
                  </td>
                  <td class="py-4 text-slate-300">{row.tech}</td>
                </tr>
              ))
            }
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <section class="border-b border-ink-800 py-16 sm:py-20">
    <div class="container-x">
      <div class="card max-w-3xl">
        <p class="eyebrow">Proof of concept</p>
        <h2 class="mt-3 text-xl font-semibold text-white">Honest about scope</h2>
        <p class="prose-muted mt-3">
          Palisade is an open proof-of-concept built on{" "}
          <a
            href={SITE.authorUrl}
            target="_blank"
            rel="noopener"
            class="text-accent-fg hover:text-white"
          >
            {SITE.authorName}'s
          </a>{" "}
          brand infrastructure. The capabilities above are implemented in the
          repository; the production operations layer — live deploy, status
          page, dashboards, and runbooks — is still being built.
        </p>
      </div>
    </div>
  </section>

  <section class="py-20 sm:py-28">
    <div class="container-x text-center">
      <p class="eyebrow">Try it</p>
      <h2 class="mx-auto mt-4 max-w-2xl text-3xl font-bold tracking-tight text-white sm:text-4xl">
        Run the control plane or read the source
      </h2>
      <div class="mt-8 flex flex-wrap justify-center gap-3">
        <a href={SITE.appUrl} class="btn-primary">Open the app</a>
        <a
          href={SITE.repoUrl}
          target="_blank"
          rel="noopener"
          class="btn-ghost"
        >
          Browse the code
        </a>
      </div>
    </div>
  </section>
</Layout>
